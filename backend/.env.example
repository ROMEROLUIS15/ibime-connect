# ==========================================
# VARIABLES DEL BACKEND (Node.js / Express)
# ==========================================
PORT=3000

# Supabase Configuration
SUPABASE_URL="https://tu_proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key"
SUPABASE_PROJECT_ID="tu_project_id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# AI APIs Configuration
GEMINI_API_KEY="tu_gemini_api_key"
GROQ_API_KEY="tu_groq_api_key"

# Modelo de GroqCloud (opcional — default: openai/gpt-oss-20b)
# `llama-3.1-8b-instant` y `llama-3.3-70b-versatile` están deprecados y dejan de
# servirse el 2026-08-16. Reemplazos: openai/gpt-oss-20b (8B) / openai/gpt-oss-120b (70B).
# GROQ_MODEL="openai/gpt-oss-20b"

# Límites REALES de tu plan de Groq para GROQ_MODEL (opcional).
# Los defaults son el free tier de openai/gpt-oss-20b. Confírmalos en la consola
# de Groq (Settings → Limits) si tienes otro plan.
# GROQ_TPM_LIMIT=8000        # tokens / minuto
# GROQ_RPM_LIMIT=30          # requests / minuto
# GROQ_RPD_LIMIT=1000        # requests / día  (se usa íntegro)
# GROQ_TPD_LIMIT=200000      # tokens / día    (se usa íntegro)
# Margen de seguridad: solo se aplica a las ventanas POR MINUTO, para absorber
# ráfagas. Las cuotas diarias se consumen completas.
# GROQ_SAFETY_MARGIN=0.8

# Caching (Redis)
# Producción con Redis Cloud: usa el prefijo rediss:// para activar TLS (el código
# lo detecta automáticamente). En local, redis:// sin TLS.
REDIS_URL="redis://localhost:6379"

# Certificado CA de Redis Cloud (PEM). Opcional. Solo si usas rediss:// y el CA de
# Redis Cloud no valida contra el bundle del sistema. Pega el PEM completo (admite
# saltos de línea reales o escapados \n). Sin esto, se valida contra las CA del SO.
# REDIS_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Frontend Configuration (para CORS)
FRONTEND_URL="http://localhost:5173"

# Admin Secret (para endpoints administrativos como flush-cache)
# Genera uno seguro: openssl rand -hex 32
ADMIN_SECRET=""

# Observability (Sentry)
# Opcional — sin DSN la captura de errores es no-op y el backend funciona igual.
# Captura los 500 reales y alerta cuando se agota la cuota diaria de Groq.
# SENTRY_DSN="https://xxxx@oyyyy.ingest.sentry.io/zzzz"

# Observability (LangSmith)
# Opcional — si no se configura, los traces simplemente no se envían.
# LANGSMITH_API_KEY="lsv2_..."
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=ibime-connect

# ==========================================
# NOTAS:
# - Copia este archivo bajo el nombre de `.env`.
# - SUPABASE_SERVICE_ROLE_KEY es una llave sensible, úsala solo en el backend.
# - Las variables de IA (GEMINI y GROQ) viven directamente en el Servidor.
# ==========================================