# ==========================================
# VARIABLES DEL BACKEND (Node.js / Express)
# ==========================================
PORT=3000

# Supabase Configuration
SUPABASE_URL="https://tu_proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key"
SUPABASE_PROJECT_ID="tu_project_id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# AI APIs Configuration
GEMINI_API_KEY="tu_gemini_api_key"
GROQ_API_KEY="tu_groq_api_key"

# Caching (Redis)
REDIS_URL="redis://localhost:6379"

# Frontend Configuration (para CORS)
FRONTEND_URL="http://localhost:5173"

# Admin Secret (para endpoints administrativos como flush-cache)
# Genera uno seguro: openssl rand -hex 32
ADMIN_SECRET=""

# ==========================================
# NOTAS:
# - Copia este archivo bajo el nombre de `.env`.
# - SUPABASE_SERVICE_ROLE_KEY es una llave sensible, úsala solo en el backend.
# - Las variables de IA (GEMINI y GROQ) viven directamente en el Servidor.
# ==========================================