# ==========================================
# VARIABLES DEL FRONTEND (Vite / React)
# ==========================================

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="tu_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://tu_proyecto.supabase.co"

# API URL (Backend). Ejemplo: http://localhost:3000/api
VITE_API_URL="http://localhost:3000"

# Cloudinary Configuration (Videos e Imágenes Optimizadas)
VITE_CLOUDINARY_CLOUD_NAME="tu_cloud_name"

# ==========================================
# NOTAS:
# - Copia este archivo bajo el nombre de `.env`.
# - En Vite, solo las variables que empiezan con VITE_ son visibles en el código.
# - NUNCA pongas llaves secretas (como SERVICE_ROLE_KEY) aquí.
# ==========================================