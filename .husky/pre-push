#!/usr/bin/env sh

# ── Pre-push Hook — Smart Error Reporter ─────────────────────────────────────
# Runs lint → typecheck → tests
# On failure: categorizes error, shows actionable message, suggests fix
# Never commits or modifies code automatically
# ──────────────────────────────────────────────────────────────────────────────

# Skip in CI environments where git hooks are not needed
if [ -n "$CI" ] || [ "$GITHUB_ACTIONS" = "true" ] || [ "$VERCEL_ENV" = "production" ] || [ "$RENDER" = "true" ]; then
  echo "Skipping pre-push hook in CI environment"
  exit 0
fi

# ── Colors (works in Git Bash, falls back gracefully in CMD) ─────────────────
if [ -t 1 ]; then
  RED='\033[0;31m'
  YELLOW='\033[1;33m'
  GREEN='\033[0;32m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  RED=""
  YELLOW=""
  GREEN=""
  CYAN=""
  BOLD=""
  NC=""
fi

pass_count=0
fail_count=0
total_stages=3

print_pass() {
  echo "${GREEN}✓${NC} $1"
  pass_count=$((pass_count + 1))
}

print_fail() {
  echo "${RED}✗${NC} $1"
  fail_count=$((fail_count + 1))
}

print_suggestion() {
  echo ""
  echo "${CYAN}Suggestion:${NC}"
  echo "   $1"
}

print_fix_command() {
  echo ""
  echo "${YELLOW}Run this to see details:${NC}"
  echo "   $1"
}

print_separator() {
  echo "───────────────────────────────────────────────────────────"
}

print_summary() {
  echo ""
  print_separator
  echo "Results: ${GREEN}${pass_count} passed${NC}, ${RED}${fail_count} failed${NC} of ${total_stages}"
  echo ""
}

# ── Stage 1: Lint ────────────────────────────────────────────────────────────
run_lint() {
  echo "${BOLD}[1/3] Running ESLint...${NC}"
  local lint_output
  lint_output=$(npm run lint 2>&1)
  local lint_exit=$?

  if [ $lint_exit -eq 0 ]; then
    print_pass "ESLint passed"
    return 0
  fi

  if echo "$lint_output" | grep -q "problems (0 errors"; then
    print_pass "ESLint passed (warnings only)"
    return 0
  fi

  print_fail "ESLint found errors"

  echo ""
  echo "${RED}Error details:${NC}"
  echo "$lint_output" | grep -A3 "error" | head -20

  print_suggestion "Fix auto-fixable issues with: ${BOLD}npm run lint -- --fix${NC}"
  print_fix_command "npm run lint"
  return 1
}

# ── Stage 2: Typecheck ──────────────────────────────────────────────────────
run_typecheck() {
  echo "${BOLD}[2/3] Running TypeScript check...${NC}"
  local tsc_output
  tsc_output=$(npm run typecheck 2>&1)
  local tsc_exit=$?

  if [ $tsc_exit -eq 0 ]; then
    print_pass "TypeScript check passed"
    return 0
  fi

  print_fail "TypeScript found errors"

  echo ""
  echo "${RED}Type errors:${NC}"
  echo "$tsc_output" | grep -E "^[a-zA-Z].*:[0-9]+:" | head -10

  print_suggestion "Review type errors and fix manually. Type issues require human context."
  print_fix_command "npm run typecheck"
  return 1
}

# ── Stage 3: Tests ───────────────────────────────────────────────────────────
run_tests() {
  echo "${BOLD}[3/3] Running tests...${NC}"
  local test_output
  test_output=$(npm test 2>&1)
  local test_exit=$?

  if [ $test_exit -eq 0 ]; then
    print_pass "All tests passed"
    return 0
  fi

  print_fail "Tests failed"

  local failed_tests
  failed_tests=$(echo "$test_output" | grep "×\|FAIL" | head -10)

  if [ -n "$failed_tests" ]; then
    echo ""
    echo "${RED}Failed tests:${NC}"
    echo "$failed_tests"
  fi

  local error_msgs
  error_msgs=$(echo "$test_output" | grep -A1 "Error:" | grep -v "^--$" | head -15)

  if [ -n "$error_msgs" ]; then
    echo ""
    echo "${RED}Error details:${NC}"
    echo "$error_msgs"
  fi

  if echo "$test_output" | grep -q "invariant expected app router"; then
    print_suggestion "Missing next/navigation mock. Add: vi.mock('next/navigation', () => ({ useRouter: () => ({...}) }))"
    print_fix_command "npm test -- __tests__/path/to/test.ts"
  elif echo "$test_output" | grep -q "is not a function"; then
    print_suggestion "Mock method missing. Check Supabase/service mocks in the test file."
    print_fix_command "npm test -- __tests__/path/to/test.ts"
  elif echo "$test_output" | grep -q "Cannot find module"; then
    print_suggestion "Import path error or missing dependency. Check imports in the test file."
    print_fix_command "npm run typecheck"
  else
    print_suggestion "Run the failing test file directly to see full error context."
    print_fix_command "npm test -- __tests__/path/to/failing-test.ts"
  fi

  return 1
}

# ── Main Execution ───────────────────────────────────────────────────────────
echo ""
echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  ${BOLD}PRE-PUSH QUALITY GATE${NC}                              ║"
echo "╚═══════════════════════════════════════════════════════════╝"
echo ""

any_failed=0

run_lint || any_failed=1
echo ""
run_typecheck || any_failed=1
echo ""
run_tests || any_failed=1

print_summary

if [ $any_failed -ne 0 ]; then
  echo "${RED}${BOLD}Push cancelled — fix errors above and retry.${NC}"
  echo ""
  exit 1
fi

echo "${GREEN}${BOLD}All checks passed! Proceeding with push...${NC}"
echo ""
exit 0