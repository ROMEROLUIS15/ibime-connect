# ==========================================
# VARIABLES DEL FRONTEND (Vite / React)
# ==========================================
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL="https://tu_variable.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="tu_anon_key"
VITE_BACKEND_URL="http://localhost:3000"

# ==========================================
# VARIABLES DEL BACKEND (Node.js / Express)
# ==========================================
PORT=3000
SUPABASE_URL="https://tu_variable.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key"
GEMINI_API_KEY="tu_gemini_api_key"
GROQ_API_KEY="tu_groq_api_key"

# -----------------------------------------------------
# NOTAS:
# - Copia este archivo bajo el nombre real de `.env`.
# - El Frontend asume que el backend corre por defecto en el puerto 3000.
# - SUPABASE_SERVICE_ROLE_KEY nunca debe llegar al Frontend, solo al Backend para realizar procesos elevados (como RAG remoto).
# - VITE_SUPABASE_PUBLISHABLE_KEY es la llave "anon" que permite iniciar al cliente publico de Supabase.
# - Las variables de IA (GEMINI y GROQ) viven directamente en el Servidor (Backend).